generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Brand {
  id                  String      @id @default(cuid())
  slug                String      @unique
  name                String
  logoUrl             String      @default("")
  primaryColor        String      @default("#000000")
  trustpilotUrl       String
  language            String      @default("en")
  shopifyDomain       String      @default("")
  shopifyClientId     String      @default("")
  shopifyClientSecret String      @default("")
  shopifyAccessToken  String      @default("")
  senderEmail         String      @default("")
  senderName          String      @default("")
  webhookId           String      @default("")
  emailEnabled        Boolean     @default(false)
  createdAt           DateTime    @default(now())
  flowEmails          FlowEmail[]
  sentEmails          SentEmail[]
}

model FlowEmail {
  id           String  @id @default(cuid())
  brand        Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId      String
  position     Int
  enabled      Boolean @default(true)
  delayMinutes Int     @default(30)
  subject      String  @default("")
  body         String  @default("")

  @@unique([brandId, position])
  @@index([brandId])
}

model SentEmail {
  id              String   @id @default(cuid())
  brand           Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId         String
  orderId         String
  flowPosition    Int      @default(1)
  customerEmail   String
  customerName    String   @default("")
  scheduledAt     DateTime
  sentAt          DateTime?
  status          String   @default("scheduled")
  createdAt       DateTime @default(now())

  @@unique([brandId, orderId, flowPosition])
  @@index([brandId])
  @@index([status, scheduledAt])
}

model Unsubscribed {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
